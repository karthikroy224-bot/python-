class x(object):
    def runningSum(self, nums):
        running_sum=0
        new_nums=[]
        for i in range (0,len(nums)):
            running_sum+=nums[i]
            new_nums.append(running_sum)
        return new_nums
            

y=[10,100,20,200]
karthik=x()
print(karthik.runningSum(y))
